{
  "name": "eds-xwalk-ai-agent",
  "version": "0.1.0",
  "tools": [
    {
      "name": "generate.block.backend",
      "description": "Generate EDS XWalk block-level JSON (Step 1) for blocks/<name>/_<name>.json.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "blockName": { "type": "string" },
          "title": { "type": "string" },
          "modelId": { "type": "string" },
          "hasModel": { "type": "boolean" },
          "fields": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "required": ["blockName", "fields"]
      }
    },
    {
      "name": "generate.block.frontend",
      "description": "Generate EDS block frontend artifacts (Step 3) from user-provided UE HTML (index-based JS + CSS).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "blockName": { "type": "string" },
          "ueHtml": { "type": "string" },
          "pattern": { "type": "string", "description": "Optional: hero|carousel|tabs (default generic)" }
        },
        "required": ["blockName", "ueHtml"]
      }
    },
    {
      "name": "validate.ueHtml",
      "description": "Validate Universal Editor HTML (Step 2 gate).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "html": { "type": "string" },
          "expectations": { "type": "object" }
        },
        "required": ["html"]
      }
    },
    {
      "name": "transform.figma.tokens",
      "description": "Extract design tokens from Figma styles (requires FIGMA_TOKEN).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fileKey": { "type": "string" },
          "nodeIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["fileKey"]
      }
    },
    {
      "name": "admin.siteConfig.read",
      "description": "Read site config (/config/{org}/sites/{site}.json).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site"]
      }
    },
    {
      "name": "admin.siteConfig.create",
      "description": "Create site config (PUT /config/{org}/sites/{site}.json).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "config": { "type": "object" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "config"]
      }
    },
    {
      "name": "admin.siteConfig.update",
      "description": "Update site config (POST /config/{org}/sites/{site}.json).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "config": { "type": "object" },
          "versionName": { "type": "string" },
          "migrate": { "type": "boolean" },
          "validate": { "type": "boolean" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "config"]
      }
    },
    {
      "name": "admin.siteConfig.delete",
      "description": "Delete site config (DELETE /config/{org}/sites/{site}.json).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site"]
      }
    },
    {
      "name": "admin.status.get",
      "description": "Get overall status of a resource (/status/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.preview.update",
      "description": "Update preview of a resource (POST /preview/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "forceUpdateRedirects": { "type": "boolean" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.live.publish",
      "description": "Publish a resource (POST /live/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "forceUpdateRedirects": { "type": "boolean" },
          "disableNotifications": { "type": "boolean" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.live.unpublish",
      "description": "Unpublish a resource (DELETE /live/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "disableNotifications": { "type": "boolean" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.cache.purge",
      "description": "Purge live cache (POST /cache/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.index.trigger",
      "description": "Trigger indexing for a resource (POST /index/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    },
    {
      "name": "admin.sitemap.generate",
      "description": "Generate sitemap (POST /sitemap/{org}/{site}/{ref}/{path}).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "site": { "type": "string" },
          "ref": { "type": "string" },
          "path": { "type": "string" },
          "apiKey": { "type": "string" },
          "authToken": { "type": "string" }
        },
        "required": ["org", "site", "ref", "path"]
      }
    }
  ]
}