### MCP server
PORT=8787

### AEM Admin API
# Base URL for admin API
# Docs: https://www.aem.live/docs/admin.html
AEM_ADMIN_API_BASE_URL=https://admin.hlx.page

# Optional defaults (do not commit real secrets)
# AEM_ADMIN_API_KEY=
# AEM_ADMIN_AUTH_TOKEN=

### Figma
# Personal access token (PAT) for server-side Figma API calls (do not commit real secrets)
# FIGMA_TOKEN=